# Local dev — requests are proxied via vite.config.ts to QA aggregator
VITE_API_URL=/api
VITE_AGGREGATOR_BASE_URL=https://qaapp.dashenbanksc.com/v2.0/chatbirrapi/aggregator

# Dashboard login credentials (validated client-side before using API token)
VITE_AUTH_USERNAME=aggregator_admin
VITE_AUTH_PASSWORD=aggregator_pass

# JWT Bearer token for QA aggregator API (required for /stats, /dlq, etc.)
# Obtain a valid token from QA auth service and paste it here.
VITE_AUTH_TOKEN=
