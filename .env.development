# Local dev — requests are proxied via vite.config.ts to staging aggregator
VITE_API_URL=/api

# Dashboard login credentials (validated client-side before using API token)
VITE_AUTH_USERNAME=aggregator_admin
VITE_AUTH_PASSWORD=aggregator_pass

# JWT Bearer token for staging aggregator API (required for /stats, /dlq, etc.)
# Obtain a valid token from your auth service and paste it here.
VITE_AUTH_TOKEN=
