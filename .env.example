# Copy to .env.local and fill in values

# API base path — use /api so Vercel rewrites or Vite proxy handle CORS
VITE_API_URL=/api

# Full QA aggregator URL (reference / healthcheck)
# https://qaapp.dashenbanksc.com/v2.0/chatbirrapi/aggregator/healthcheck
VITE_AGGREGATOR_BASE_URL=https://qaapp.dashenbanksc.com/v2.0/chatbirrapi/aggregator

# Dashboard login (client-side gate; must match what you distribute to operators)
VITE_AUTH_USERNAME=aggregator_admin
VITE_AUTH_PASSWORD=your-secure-password

# JWT issued by your auth service — used as Bearer token on protected aggregator routes
VITE_AUTH_TOKEN=your-jwt-token-here
